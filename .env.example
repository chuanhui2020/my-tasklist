# ==============================================
# 任务管理系统 Docker Compose 环境变量配置
# ==============================================
#
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据实际情况修改下面的配置
# 3. 执行 docker compose up -d 启动服务
#
# ==============================================

# ----------------------------------------------
# MySQL 数据库配置
# ----------------------------------------------
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=tasklist_db
MYSQL_USER=taskuser
MYSQL_PASSWORD=your_secure_user_password_here
MYSQL_PORT=3306

# ----------------------------------------------
# 后端配置
# ----------------------------------------------
# 重要：生产环境必须修改此密钥！
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# CORS 允许的前端域名（逗号分隔）
CORS_ORIGINS=https://tasklist.ch-tools.org,http://localhost:3000

# ----------------------------------------------
# 前端配置
# ----------------------------------------------
# 前端访问端口
FRONTEND_PORT=3000

# ----------------------------------------------
# AI 服务配置（算命、BMI 建议等功能）
# ----------------------------------------------
# OpenAI 兼容接口（DeepSeek / SiliconFlow / 智谱 / OpenAI 等）
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ----------------------------------------------
# 其他配置
# ----------------------------------------------
# 时区（可选）
TZ=Asia/Shanghai
